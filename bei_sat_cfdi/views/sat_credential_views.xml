<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- ACTION -->
  <record id="action_bei_sat_credential" model="ir.actions.act_window">
    <field name="name">Credenciales SAT</field>
    <field name="res_model">bei.sat.credential</field>
    <field name="view_mode">tree,form</field>
    <field name="context">{'default_company_id': allowed_company_ids[0]}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Configura la e.firma para descargar CFDI desde el SAT.
        </p>
    </field>
  </record>

  <!-- TREE -->
  <record id="view_bei_sat_credential_tree" model="ir.ui.view">
    <field name="name">bei.sat.credential.tree</field>
    <field name="model">bei.sat.credential</field>
    <field name="arch" type="xml">
      <tree>
        <field name="active" widget="boolean_toggle"/>
        <field name="company_id"/>
        <field name="rfc"/>
        <field name="tipo_documento"/>
        <field name="tipo_comprobante"/>
        <field name="cron_days_back"/>
      </tree>
    </field>
  </record>

  <!-- FORM -->
  <record id="view_bei_sat_credential_form" model="ir.ui.view">
    <field name="name">bei.sat.credential.form</field>
    <field name="model">bei.sat.credential</field>
    <field name="arch" type="xml">
      <form string="Credencial SAT">
        <header>
          <button name="action_open_download_wizard"
                  string="Descargar ahora"
                  type="object"
                  class="btn-primary"/>
        </header>
        <sheet>
          <div class="oe_button_box" name="button_box">
            <button name="action_view_requests" type="object" class="oe_stat_button" icon="fa-cloud-download">
              <field name="request_count" widget="statinfo" string="Solicitudes"/>
            </button>
          </div>

          
          <div class="oe_title">
            <h1>
              <field name="display_name" readonly="1"/>
            </h1>
          </div>

          <group>
            <group>
              <field name="active"/>
              <field name="company_id" options="{'no_create': True}"/>
              <field name="rfc"/>
            </group>
            <group>
              <field name="tipo_documento"/>
              <field name="tipo_comprobante"/>
              <field name="download_mode"/>
              <field name="cron_days_back"/>
            </group>
          </group>

          <notebook>
            <page string="e.firma">
              <group>
                <group string="Certificado (.cer)">
                  <field name="cer_filename" placeholder="archivo.cer"/>
                  <field name="cer_file" filename="cer_filename"/>
                </group>
                <group string="Llave privada (.key)">
                  <field name="key_filename" placeholder="archivo.key"/>
                  <field name="key_file" filename="key_filename"/>
                  <field name="key_password" password="True"/>
<!--                  <field name="key_password" password="True"/>-->
                </group>
              </group>
              <div class="text-muted">
                <p>
                  * La Descarga Masiva del SAT requiere e.firma (CER/KEY + contraseña).
                </p>
              </div>
            </page>

<!--            <page string="Auditoría">-->
<!--              <group>-->
<!--                <field name="message_follower_ids" widget="mail_followers"/>-->
<!--                <field name="activity_ids" widget="mail_activity"/>-->
<!--              </group>-->
<!--            </page>-->
          </notebook>
        </sheet>

        <div class="oe_chatter">
          <field name="message_follower_ids" widget="mail_followers"/>
          <field name="activity_ids" widget="mail_activity"/>
          <field name="message_ids" widget="mail_thread"/>
        </div>
      </form>
    </field>
  </record>

  <!-- MENU: Accounting / Configuration / Accounting (al final) -->
  <menuitem
    id="menu_bei_sat_credential"
    name="Credenciales SAT"
    parent="account.menu_finance_configuration"
    action="action_bei_sat_credential"
    sequence="999"
    groups="bei_sat_cfdi.group_sat_cfdi_manager"
  />
</odoo>